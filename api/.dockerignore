# Git
.git
.gitignore

# 依存（イメージ内で composer / npm install するため除外）
/vendor
/node_modules

# 環境・秘密（.env.example だけは残す）
.env
.env.*
!.env.example

# Docker メタファイル
Dockerfile
.dockerignore

# ランタイム生成物・ログ（ディレクトリ自体は残す）
/storage/logs/*
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/bootstrap/cache/*.php
.phpunit.result.cache

# OS
*.log
.DS_Store
