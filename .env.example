#==============================================================
# docker-compose 用の環境変数（テンプレート）
#
#  使い方： cp .env.example .env してから値を編集
#  ※ .env.example は git にコミットする（秘密情報は書かない）
#==============================================================

# ---- 公開ポート（ホスト側） ----
WEB_PORT=3000
API_PORT=8000
REVERB_PORT=8080
DB_PORT=3306
REDIS_PORT=6379

# ---- MySQL ----
DB_DATABASE=buddy
DB_USERNAME=buddy
DB_PASSWORD=change_me        # 本番では必ず強いパスワードに
DB_ROOT_PASSWORD=change_me   # 本番では必ず強いパスワードに
